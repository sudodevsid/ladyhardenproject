import json
import socket
import time
from concurrent.futures import ThreadPoolExecutor

from kafka import KafkaConsumer


def vehicle_number_from_message(data: bytes) -> str:
    text = data.decode("utf-8", errors="replace").strip()
    try:
        event = json.loads(text)
    except json.JSONDecodeError:
        return text

    if isinstance(event, dict):
        return str(event.get("vehicle_number") or event.get("vehicleNumber") or "").strip()
    return str(event).strip()


def open_barrier(vehicle_number: str) -> None:
    client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    client.settimeout(1)

    try:
        client.connect(("127.0.0.1", 5000))
        client.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
        client.sendall("|OPENEN%".encode("ascii"))
        print(f"barrier opened for {vehicle_number}", flush=True)
    except OSError as error:
        print(f"barrier failed for {vehicle_number}: {error}", flush=True)
    finally:
        client.close()


def kafka_consumer() -> KafkaConsumer:
    while True:
        try:
            return KafkaConsumer(
                "vehicle.events",
                bootstrap_servers=["localhost:9092"],
                group_id="barrier-service",
                auto_offset_reset="latest",
                enable_auto_commit=True,
            )
        except Exception as error:
            print(f"kafka not ready at localhost:9092: {error}", flush=True)
            print("retrying in 3 seconds...", flush=True)
            time.sleep(3)


def main() -> None:
    print("barrier listening topic=vehicle.events kafka=localhost:9092", flush=True)
    print("barrier socket=127.0.0.1:5000 command=|OPENEN%", flush=True)

    consumer = kafka_consumer()
    with ThreadPoolExecutor(max_workers=4) as pool:
        for message in consumer:
            vehicle_number = vehicle_number_from_message(message.value)
            if not vehicle_number:
                print("empty vehicle number skipped", flush=True)
                continue
            print(f"barrier message received: {vehicle_number}", flush=True)
            pool.submit(open_barrier, vehicle_number)


if __name__ == "__main__":
    main()
