import argparse
import json
import os
import time
from datetime import datetime, timezone
from uuid import uuid4

from kafka import KafkaProducer


KAFKA_BOOTSTRAP = os.getenv("KAFKA_BOOTSTRAP", "localhost:9092")
KAFKA_TOPIC = os.getenv("KAFKA_TOPIC", "vehicle.events")
KAFKA_RETRY_SECONDS = float(os.getenv("KAFKA_RETRY_SECONDS", "3"))


def send_vehicle_event(vehicle_number: str, lane_id: str = "1") -> None:
    event = {
        "vehicle_number": vehicle_number.strip(),
        "lane_id": lane_id,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "event_id": str(uuid4()),
    }

    data = json.dumps(event).encode("utf-8")
    while True:
        try:
            producer = KafkaProducer(
                bootstrap_servers=KAFKA_BOOTSTRAP.split(","),
                acks="all",
                retries=3,
                linger_ms=0,
            )
            result = producer.send("vehicle.events", data).get(timeout=10)
            producer.flush()
            producer.close()
            break
        except Exception as error:
            print(f"kafka not ready at {KAFKA_BOOTSTRAP}: {error}")
            print(f"retrying in {KAFKA_RETRY_SECONDS} seconds...")
            time.sleep(KAFKA_RETRY_SECONDS)

    print(
        f"sent {event['vehicle_number']} "
        f"topic={result.topic} partition={result.partition} offset={result.offset}"
    )


def main() -> None:
    parser = argparse.ArgumentParser(description="Produce vehicle event to Kafka.")
    parser.add_argument("vehicle_number", nargs="?", help="Example: RJ14AB1234")
    parser.add_argument("--lane-id", default="1")
    args = parser.parse_args()

    vehicle_number = args.vehicle_number or input("Vehicle number: ").strip()
    if not vehicle_number:
        raise SystemExit("vehicle number required")

    send_vehicle_event(vehicle_number, args.lane_id)


if __name__ == "__main__":
    main()


