import json
import time

import serial
from kafka import KafkaConsumer


def clear_command() -> str:
    return "|C|1|6|"


def message_command(text: str) -> str:
    safe_text = "".join(ch for ch in text.strip() if 32 <= ord(ch) <= 126)
    return f"|C|1|4|1|0-0-#{safe_text}|"


def vehicle_number_from_message(data: bytes) -> str:
    text = data.decode("utf-8", errors="replace").strip()
    try:
        event = json.loads(text)
    except json.JSONDecodeError:
        return text

    if isinstance(event, dict):
        return str(event.get("vehicle_number") or event.get("vehicleNumber") or "").strip()
    return str(event).strip()


def write_command(port: serial.Serial, command: str) -> None:
    port.write(command.encode("ascii", errors="replace"))
    port.flush()
    print(f"display sent {command}", flush=True)
    time.sleep(0.02)


def show_vehicle(port: serial.Serial, vehicle_number: str) -> None:
    write_command(port, clear_command())
    write_command(port, message_command(vehicle_number))
    write_command(port, clear_command())
    write_command(port, message_command("WELCOME"))


def kafka_consumer() -> KafkaConsumer:
    while True:
        try:
            return KafkaConsumer(
                "vehicle.events",
                bootstrap_servers=["localhost:9092"],
                group_id="display-service",
                auto_offset_reset="latest",
                enable_auto_commit=True,
            )
        except Exception as error:
            print(f"kafka not ready at localhost:9092: {error}", flush=True)
            print("retrying in 3 seconds...", flush=True)
            time.sleep(3)


def main() -> None:
    print("display listening topic=vehicle.events kafka=localhost:9092", flush=True)
    print("display serial=COM3 baudrate=9600", flush=True)

    consumer = kafka_consumer()
    with serial.Serial("COM3", 9600, timeout=1, write_timeout=1) as port:
        for message in consumer:
            vehicle_number = vehicle_number_from_message(message.value)
            if not vehicle_number:
                print("empty vehicle number skipped", flush=True)
                continue
            print(f"display message received: {vehicle_number}", flush=True)
            show_vehicle(port, vehicle_number)


if __name__ == "__main__":
    main()

