from kafka import KafkaConsumer
def main() -> None:
    print("barrier listening topic=vehicle.events kafka=localhost:9092", flush=True)
    consumer = KafkaConsumer("vehicle.events",bootstrap_servers=["localhost:9092"],group_id="barrier-service",auto_offset_reset="latest",enable_auto_commit=True,)
    for message in consumer:
        print(f"barrier message received: {message.value.decode('utf-8')}", flush=True)

if __name__ == "__main__":
    main()

